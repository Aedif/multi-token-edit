<li class="directory-item entry document scene flexrow" data-id="{{_id}}" data-uuid="{{uuid}}" style="display: flex; position: relative; border-top: var(--sidebar-separator, 1px solid var(--color-dark-1)); margin-bottom: 0;">
    <img style="flex: 0 0 48px; height: 48px; width: 48px; object-fit: cover; object-position: 50% 0; border: none; margin-right: 5px;" src="{{thumb}}" alt="{{name}}" loading="lazy">
    <a class="entry-name ellipsis" data-tooltip="{{name}}">{{name}}</a>
</li>